			<item>
				<title>Encrypt Decrypt With Gpg</title>
				<link>https://karthick.it/posts/2020/10/encrypt-decrypt-with-gpg/</link>
				<pubDate>Fri, 30 Oct 2020 00:00:09 +0530</pubDate>
